# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env — it is gitignored.

# Runtime environment: "development" | "production"
ENVIRONMENT=development

# Secret used to sign JWTs. Generate a strong one for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# In production the app refuses to start with the insecure default.
SECRET_KEY=change-me-in-production

# Database.
# Local dev: SQLite file (below). Production: use PostgreSQL — e.g. on Railway,
# reference the Postgres service's URL: DATABASE_URL=${{Postgres.DATABASE_URL}}
# (postgres:// and postgresql:// URLs are auto-adapted to the psycopg driver).
DATABASE_URL=sqlite:///./im_telligence.db

# Where uploaded lesson PDFs are stored. In production point this at a PERSISTENT
# disk (e.g. a Railway Volume mounted at /data) so uploads survive redeploys:
#   UPLOAD_DIR=/data/files
UPLOAD_DIR=./storage/files

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed frontend origins (CORS). In production set the
# exact frontend URL(s), e.g. CORS_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Cookies. In production over HTTPS set COOKIE_SECURE=true. When the frontend and
# API are on DIFFERENT domains (e.g. two Railway services), the auth cookie is
# cross-site, so also set COOKIE_SAMESITE=none (which requires COOKIE_SECURE=true).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Account lockout
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# First-run super-admin bootstrap. On a fresh DB with no super-admin, if both of
# these are set an active super-admin is created at startup (no-op once one
# exists). Essential for a fresh production database — you can't log in without it.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Super Admin

# Teacher AI assistant.
# AI_PROVIDER picks the active model: mock | groq | grok | openai | anthropic.
# If the chosen provider's key is empty, the app falls back to "mock" (no key
# needed) so the chat still works in development.
# NOTE: "groq" (groq.com, keys gsk_...) and "grok" (xAI, keys xai-...) are
# different providers — don't confuse them.
AI_PROVIDER=groq
GROQ_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROK_MODEL=grok-2-latest
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Email delivery for DB backups ---
# Resend (https://resend.com) is preferred for production. If RESEND_API_KEY is
# set, backups are emailed via Resend; otherwise the SMTP settings below are
# used. For production set RESEND_FROM to a verified-domain address; the shared
# onboarding@resend.dev only delivers to your own Resend account email.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# SMTP — fallback for emailing the database backup (download works without it).
# Example for Gmail: host=smtp.gmail.com, port=587, user=you@gmail.com,
# password=<16-char app password, no spaces>, tls=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# --- Automated daily database backup ---
# When enabled, the server emails a full DB backup to BACKUP_EMAIL_TO every
# BACKUP_INTERVAL_HOURS, using the email provider resolved above.
BACKUP_EMAIL_ENABLED=false
BACKUP_EMAIL_TO=
BACKUP_INTERVAL_HOURS=24

# --- Admin notifications ---
# Where teacher lesson-access requests are emailed. If empty, all super-admin
# account emails are used instead.
ADMIN_EMAIL=
